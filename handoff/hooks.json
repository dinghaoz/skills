{
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_pre_tool_use_bash.py\"",
          "timeout": 5
        }
      ]
    }
  ],
  "Notification": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_notification.py\"",
          "timeout": 15
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/permission_bridge.py\"",
          "timeout": 3600
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write|Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_post_tool_use.py\"",
          "timeout": 15
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "matcher": "Edit|Write|Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_post_tool_use.py\"",
          "timeout": 15
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_pre_compact.py\"",
          "timeout": 15
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_session_start.py\"",
          "timeout": 10
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/skills/handoff/scripts/on_session_end.py\"",
          "timeout": 15
        }
      ]
    }
  ]
}
